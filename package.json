{
	"name": "my-library",
	"description": "A base template for building a shareable web components library with Vite + Svelte",
	"version": "0.0.0",
	"type": "module",
	"module": "dist/lib/my-library.js",
	"main": "dist/lib/my-library.umd.js",
	"scripts": {
		"start": "npm run dev -s",
		"dev": "vite --config vite.demo.config.ts",
		"build": "vite build",
		"build:demo": "vite build --config vite.demo.config.ts",
		"preview": "vite preview --config vite.demo.config.ts",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"prepublishOnly": "npm run build -s",
		"format": "prettier --write .",
		"storybook": "storybook dev -p 6006",
		"build-sb": "storybook build",
		"serve-sb": "http-server storybook-static -p 6006",
		"vrt:capture": "npm run build-sb && concurrently --kill-others --success command-1 --names serve,cap \"npm run serve-sb\" \"wait-on http://localhost:6006 && node scripts/storycap.mjs\"",
		"vrt": "npm run vrt:capture && reg-suit run",
		"vrt:approve": "rm -rf .reg/expected && mkdir -p .reg/expected && cp -R __screenshots__/. .reg/expected/"
	},
	"devDependencies": {
		"@storybook/addon-essentials": "^7.6.24",
		"@storybook/blocks": "^7.6.24",
		"@storybook/svelte": "^7.6.24",
		"@storybook/svelte-vite": "^7.6.24",
		"@sveltejs/vite-plugin-svelte": "^2.0.2",
		"@tsconfig/svelte": "^3.0.0",
		"concurrently": "^9.1.0",
		"http-server": "^14.1.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"puppeteer": "^25.0.4",
		"reg-suit": "^0.14.5",
		"storybook": "^7.6.24",
		"storycap": "^4.3.1",
		"svelte": "^3.52.0",
		"svelte-check": "^3.0.3",
		"svelte-preprocess": "^5.0.1",
		"wait-on": "^7.2.0",
		"tslib": "^2.4.0",
		"typescript": "^4.6.4",
		"vite": "^4.0.4"
	},
	"files": [
		"dist/lib"
	]
}
